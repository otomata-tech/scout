# scout standalone server — env

# Postgres (required). Run `npm run migrate` once to create the schema.
DATABASE_URL=postgres://postgres@127.0.0.1:5432/scout

# HTTP port (default 8100)
PORT=8100

# Serve a built frontend in the same process (single deployable).
# Point at the Vite build output; leave empty to run API-only.
# STATIC_DIR=../frontend/dist

# Auth (Logto OIDC). Leave BOTH empty for dev bypass (request.user = dev-bypass).
LOGTO_ENDPOINT=
LOGTO_AUDIENCE=

# Personal API-token prefix (used by the token verifier).
API_TOKEN_PREFIX=scout_
