{
  "name": "@otomata/scout-server",
  "version": "0.2.0",
  "description": "scout : standalone lead-enrichment SaaS + reusable server shell (Fastify, Logto JWT, generic services).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cache": "./src/cache.ts",
    "./auth": "./src/auth.ts",
    "./oauth": "./src/oauth.ts",
    "./build-app": "./src/build-app.ts",
    "./db": "./src/db.ts",
    "./mcp": "./src/mcp.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./services/recherche-entreprises": "./src/services/recherche-entreprises.ts",
    "./services/kaspr": "./src/services/kaspr.ts",
    "./services/fullenrich": "./src/services/fullenrich.ts",
    "./services/logto": "./src/services/logto.ts",
    "./services/access": "./src/services/access.ts",
    "./services/api-tokens": "./src/services/api-tokens.ts",
    "./services/provider-calls": "./src/services/provider-calls.ts",
    "./services/claude-md": "./src/services/claude-md.ts",
    "./services/mailer": "./src/services/mailer.ts",
    "./services/presence": "./src/services/presence.ts",
    "./services/entity-log": "./src/services/entity-log.ts",
    "./services/claimable": "./src/services/claimable.ts",
    "./services/waterfall": "./src/services/waterfall.ts",
    "./services/leads": "./src/services/leads.ts"
  },
  "scripts": {
    "dev": "tsx watch src/serve.ts",
    "build": "tsc",
    "start": "node dist/serve.js",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "fastify": "^5.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "jose": "^5.0.0",
    "zod": "^3.0.0",
    "postgres": "^3.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "postgres": { "optional": true },
    "@modelcontextprotocol/sdk": { "optional": true }
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^5.9.6",
    "zod": "^3.24.1",
    "postgres": "^3.4.5",
    "@modelcontextprotocol/sdk": "^1.0.4"
  }
}
