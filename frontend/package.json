{
  "name": "@otomata/scout-frontend",
  "version": "0.1.0",
  "description": "Vue 3 shell for scout : DashboardLayout, theme loader, generic UI components, shadcn-vue primitives.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/assets/theme.css",
    "./shell/*": "./src/shell/*.vue",
    "./components/ui/*": "./src/components/ui/*"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "dependencies": {
    "@vueuse/core": "^12.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.541.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.5",
    "@vue/tsconfig": "^0.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  }
}
