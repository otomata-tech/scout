{
  "name": "@otomata/scout-frontend",
  "version": "0.2.0",
  "description": "scout frontend : standalone SaaS host app + Vue 3 shell library (DashboardLayout, theme, generic UI primitives).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/assets/theme.css",
    "./shell/*": "./src/shell/*.vue",
    "./components/ui/*": "./src/components/ui/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "@logto/browser": "^3.0.0",
    "marked": "^18.0.0"
  },
  "dependencies": {
    "@vueuse/core": "^12.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.541.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@logto/browser": "^3.0.13",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "marked": "^18.0.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "vite": "^8.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  }
}
